<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
 <record id="repair_email_template" model="mail.template">
    <field name="name">Repair Email</field>
     <field name="model_id" ref="vehicle_repair_management.model_vehicle_repair"/>
    <field name="subject">Vehicle Repair Team</field>
    <field name="partner_to">{{ object.partner_id.id }}</field>
    <field name="body_html" type="html">
        <p>Hello, <br/>your vehicle is ready.</p>
     <table border="1" cellpadding="1" cellspacing="0">
         <tr>
             <th>Reference: </th>
             <th>Vehicle Type:</th>
             <th>Vehicle Number:</th>
             <th>Vehicle Model:</th>
             <th>Labor Cost:</th>
             <th>Parts Cost::</th>
             <th> Total Cost:</th>
         </tr>
         <tr>
             <td><t t-out="object.reference"/></td>
             <td><t t-out="object.vehicle_type_id.name"/></td>
             <td><t t-out="object.vehicle_number"/></td>
             <td><t t-out="object.vehicle_model_id.name"/></td>
             <td><t t-out="object.total_labor_cost" /></td>
             <td><t t-out="object.total_parts_cost"/></td>
             <td><t t-out="object.total_parts_labor_cost"/></td>
         </tr>

    </table>
    </field>
</record>
    </data>
</odoo>
