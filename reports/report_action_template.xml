<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<record id="action_report_repair_wizard" model="ir.actions.report">
    <field name="name">Repair Analysis Report</field>
    <field name="model">repair.report.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">vehicle_repair_management.report_repair_details_template</field>
    <field name="report_file">vehicle_repair_management.report_repair_details_template</field>
    <field name="binding_model_id" ref="model_repair_report_wizard"/>
</record>
<template id="report_repair_details_template">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <div class="page">
                <div class="oe_structure"/>

                <center><h2>Repair Analysis Report</h2></center>

                <div class="row mt32 mb32">
                    <div class="col-6" t-if="single_customer">
                        <strong>Customer: </strong><span t-esc="single_customer"/>
                    </div>
                    <div class="col-6" t-if="single_advisor">
                        <strong>Service Advisor: </strong><span t-esc="single_advisor"/>
                    </div>
                </div>

                <table class="table table-sm o_main_table">
                    <thead>
                        <tr>
                            <th>Vehicle Model</th>
                            <th>Vehicle Number</th>
                            <th t-if="customer_count > 1">Customer</th>
                            <th t-if="advisor_count > 1">Advisor</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>State</th>
                            <th>Vehicle Type</th>
                            <th>Service Type</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="docs" t-as="o">
                            <tr>
                                <td><span t-esc="o['model']"/></td>
                                <td><span t-esc="o['vehicle_number']"/></td>
                                <td t-if="customer_count > 1"><span t-esc="o['customer']"/></td>
                                <td t-if="advisor_count > 1"><span t-esc="o['advisor']"/></td>
                                <td><span t-esc="o['start_date']"/></td>
                                <td><span t-esc="o['end_date']"/></td>
                                <td><span t-esc="o['state']"/></td>
                                <td><span t-esc="o['vehicle_type']"/> </td>
                                <td><span t-esc="o['service_type']"/> </td>
                                <td><span t-esc="o['total_amount']"/></td>

                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </t>
</template>



</odoo>


