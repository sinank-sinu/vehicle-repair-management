<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="res.groups.privilege" id="res_groups_privilege_vehicl_repair_managemnet">
        <field name="name">Vehicle Repair Management</field>
    </record>

    <record id="group_technician" model="res.groups">
        <field name="name">Technician: Manage all </field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_vehicl_repair_managemnet"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="comment">The user will have access to the human resources configuration as well as statistic reports.</field>
        <field name="privilege_id" ref="res_groups_privilege_vehicl_repair_managemnet"/>
        <field name="implied_ids" eval="[(4, ref('group_technician'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
<record id="technician_record_rule" model="ir.rule">
    <field name="name">Technicians: see own records only</field>
    <field name="model_id" ref="model_vehicle_repair"/>
    <field name="domain_force">[('create_uid', '=', user.id)]</field>
    <field name="groups" eval="[(4, ref('group_technician'))]"/>
    <field name="perm_read" eval="True"/>
    <field name="perm_write" eval="True"/>
    <field name="perm_create" eval="True"/>
    <field name="perm_unlink" eval="False"/>
</record>
    <record id="manager_admin" model="ir.rule">
        <field name="name">Administrators can view all</field>
        <field name="model_id" ref="model_vehicle_repair"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(ref('vehicle_repair_management.group_manager'))]"/>
    </record>
    <record id="journal_group_comp_rule" model="ir.rule">
    <field name="name">Multi-company: Single Company Visibility</field>
    <field name="model_id" ref="model_vehicle_repair"/>
    <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    <field name="global" eval="True"/>
    </record>

</odoo>
