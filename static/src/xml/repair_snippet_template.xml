<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="vehicle_repair_management.category_data">
        <div t-att-id="carousel_id" class="carousel slide carousel-fade" data-bs-ride="carousel">
            <div class="carousel-inner">
                <t t-foreach="chunks" t-as="chunk" t-key="chunk_index">
                    <div t-attf-class="carousel-item #{chunk.is_active ? 'active' : ''}">
                        <div class="container my-4">
                            <div class="row g-4 justify-content-center">
                                <t t-foreach="chunk" t-as="repair" t-key="repair.id">
                                    <div class="col-md-3">
                                        <div class="card shadow-lg h-100"
                                             style="border-radius: 10px; background-color: #f8f9fb;">
                                            <div class="card-body p-4">
                                                <div class="text-center">
                                                    <div class="position-relative"
                                                         style="height: 180px; background-color: #e9ecef;
                                                          overflow: hidden; border-radius: 5px;">
                                                        <t t-if="repair.image_1920">
                                                            <img t-attf-src="data:image/png;base64,{{repair.image_1920}}"
                                                                 class="w-100 h-100" style="object-fit: cover;"/>
                                                        </t>
                                                        <t t-else="">
                                                            <img src="/vehicle_repair_management/static/src/img/image.jpeg"
                                                                 class="img img-fluid"/>
                                                        </t>
                                                    </div>
                                                    <div class="mt-3 text-start">
                                                        <p class="small mb-1"><strong>Customer:</strong>
                                                            <t t-esc="repair.partner_id[1]"/></p>
                                                        <p class="small mb-1"><strong>Type:</strong>
                                                            <t t-esc="repair.vehicle_type_id[1]"/></p>
                                                        <p class="small mb-1"><strong>Model:</strong>
                                                            <t t-esc="repair.vehicle_model_id[1]"/></p>
                                                        <p class="small mb-1"><strong>Plate:</strong>
                                                            <t t-esc="repair.vehicle_number"/></p>
                                                    </div>
                                                    <div class="mt-3">
                                                        <a t-attf-href="/odoo/action-939/#{repair.id}"
                                                           class="btn btn-primary rounded-pill btn-sm w-100">
                                                            View Details</a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <button class="carousel-control-prev" type="button" t-attf-data-bs-target="##{carousel_id}"
                    data-bs-slide="prev" aria-label="Previous" title="Previous" style="width: 5%;">
                <span class="oi oi-chevron-left ms-md-n4 rounded-pill p-3 bg-700"/>
            </button>
            <button class="carousel-control-next" type="button" t-attf-data-bs-target="##{carousel_id}"
                        data-bs-slide="next" aria-label="Next" title="Next" style="width: 5%;">
                <span class="oi oi-chevron-right me-md-n4 rounded-pill p-3 bg-700"/>
            </button>
        </div>
    </t>
</templates>
