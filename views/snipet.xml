<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<template id="basic_snippet" name="Basic Snippet">
    <section class="container top_repairs">
        <div class="row">
            <div class="col-md-12">
                <h4 class="text-center mb-4">Top 4 Vehicle Repairs</h4>
                <div class=" text-center">Loading repairs</div>
            </div>
        </div>
    </section>
</template>

    <template id="external_snippets" name="temp" inherit_id="website.snippets">
        <xpath expr="//snippets[@id='snippet_groups']" position="inside">
            <t snippet-group="temp1" t-snippet="vehicle_repair_management.basic_snippet"/>
        </xpath>

    </template>
    <template id="external_snippets_two" name="temp" inherit_id="website.snippets">
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t group="temp1" t-snippet="vehicle_repair_management.basic_snippet"/>
        </xpath>
    </template>



</odoo>
