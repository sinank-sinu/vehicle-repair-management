<?xml version="1.0" ?>
<odoo>

    <record id="vehicle_repair_tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">vehicle.repair.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="vehicle_repair_tag_view" model="ir.ui.view">
        <field name="name">vehicle.repair.tag.list</field>
        <field name="model">vehicle.repair.tag</field>
        <field name="arch" type="xml">
            <list string="Tags">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="vehicle_repair_tag_form" model="ir.ui.view">
        <field name="name">vehicle.repair.tag.form</field>
        <field name="model">vehicle.repair.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
