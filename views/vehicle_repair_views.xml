<?xml version="1.0"?>
<odoo>

    <record id="vehicle_repair_action" model="ir.actions.act_window">
        <field name="name">vehicle_repair</field>
        <field name="res_model">vehicle.repair</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="vehicle_repair_view" model="ir.ui.view">
        <field name="name">vehicle_repair.list</field>
        <field name="model">vehicle.repair</field>
        <field name="arch" type="xml">
            <list string="vehicle_repair_management">
                <field name="partner_id"/>
                <field name="mobile_no"/>
                <field name="salesperson_id"/>
                <field name="estimated_amount"/>
                 <field name="total_parts_labor_cost"/>
                <field name="tag_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}" readonly="state == 'in progress'"/>
                <field name="state" decoration-danger="state in ['cancel']" decoration-success="state in ['done']"/>
            </list>
        </field>
    </record>

    <record id="vehicle_repair_view_form" model="ir.ui.view">
        <field name="name">vehicle_repair_form</field>
        <field name="model">vehicle.repair</field>
        <field name="arch" type="xml">
            <form string="vehicle repair management">
                <header>
                    <button name="action_confirm" type="object"
                            string="Confirm" class="oe_highlight"
                            invisible="state in ('in progress', 'ready for delivery','done','cancel')"/>
                    <button name="action_ready_for_delivery" type="object"
                            string="Ready for Delivery" class="oe_highlight"
                            invisible="state in ('cancel','draft','ready for delivery','done')"/>
                    <button name="action_done" type="object"
                            string="Done" class="oe_highlight"
                            invisible="state in ('cancel','draft','in progress','done')"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('done', 'cancel')"/>
                    <button name="action_create_invoice"
                            string="Create Invoice"
                            type="object" class="oe_highlight"
                            invisible="state in ('draft','in progress','ready for delivery','cancel')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in progress,ready for delivery,done"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                    <field name="invoice_count" invisible="1"/>
                    <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-pencil-square-o"
                            invisible="state in ('cancel','draft','in progress','ready for delivery')">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value"><field name="invoice_count"/></span>
                            <span class="o_stat_text">Invoice</span>
                        </div>
                    </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active != False"/>
                    <widget name="web_ribbon" title="Paid" bg_color="text-bg-success"
                            invisible="payment_state not in ('paid', 'in_payment')"/>

                    <div class="oe_title">
                        <h1><field name="reference" readonly="1"/></h1>
                    </div>

                    <field name="image_1920" class="oe_avatar" widget="image"/>
                    <group>
                        <group>
                            <field name="partner_id" widget="res_partner_many2one" placeholder="Customer..."
                                   readonly="state == 'done'"/>
                            <field name="active"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"
                                   readonly="state == 'in progress'"/>
                            <field name="company_id"/>
                            <field name="estimated_amount" widget="monetary" readonly="state == 'in progress'"/>
                            <field name="service_type" required="1" readonly="state == 'in progress'"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="start_date" readonly="state == 'in progress'"/>
                            <field name="vehicle_type_id" readonly="state == 'in progress'"/>
                            <field name="vehicle_model_id" readonly="state == 'in progress'"/>
                            <field name="vehicle_number" readonly="state == 'in progress'"/>
                            <field name="salesperson_id" readonly="state == 'in progress'"/>
                            <field name="mobile_no"/>
                            <field name="estimated_date"/>
                            <field name="deliver_date" invisible="state in ('draft','in progress','ready for delivery','cancel')"/>

                        </group>
                    </group>

                    <notebook>
                        <page string="Customer Complaint">
                            <field name="customer_complaint" placeholder="Type issue here..."/>
                        </page>

                        <page string="Labor Cost" invisible="service_type != 'paid'">
                            <field name="labor_line_ids">
                                <list editable="bottom">
                                    <field name="detail"/>
                                    <field name="employee_id"/>
                                    <field name="hours_spent" />
                                    <field name="hourly_cost" widget="monetary"/>
                                    <field name="subtotal" widget="monetary" />
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_labor_cost" class="oe_subtotal_footer_separator" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Consumed Parts">
                                  <field name="consumed_part_ids">
                                      <list editable="bottom">
                                          <field name="product_id"/>
                                          <field name="qty"/>
                                          <field name="unit_price" widget="monetary"/>
                                          <field name="subtotal" widget="monetary"/>
                                      </list>
                                  </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_parts_cost" class="oe_subtotal_footer_separator" widget="monetary"/>
                            </group>
                        </page>
                    </notebook>
                     <group class="oe_subtotal_footer oe_right">
                                <field name="total_parts_labor_cost" class="oe_subtotal_footer_separator"
                                       widget="monetary"/>
                     </group>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
