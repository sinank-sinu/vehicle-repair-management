<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_repair_report_wizard" model="ir.actions.act_window">
    <field name="name">Repair Report</field>
    <field name="res_model">repair.report.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>

<record id="view_vehicle_repair_report_wizard" model="ir.ui.view">
    <field name="name">vehicle.repair.report.wizard.form</field>
    <field name="model">repair.report.wizard</field>
    <field name="arch" type="xml">
        <form>
            <group>
                <group>
                    <field name="start_date"/>
                    <field name="partner_ids" widget="many2many_tags"/>
                </group>
                <group>
                    <field name="end_date"/>
                    <field name="salesperson_ids" widget="many2many_tags"/>
                </group>
            </group>
            <footer>
                <button name="action_print_report" string="Print PDF" icon="fa-print" type="object" class="btn-primary"/>
                <button name="action_print_xlsx" string="Print xlsx" icon="fa-print" type="object" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
</odoo>